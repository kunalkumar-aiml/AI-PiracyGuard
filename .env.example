# AI-PiracyGuard Environment Variables
# Copy this file to .env and fill in your values.

# Flask secret key for JWT signing (REQUIRED - no default)
SECRET_KEY=change-me-to-a-strong-random-secret

# Admin credentials for /login endpoint (REQUIRED)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Set to 'true' to enable Flask debug mode (default: false)
FLASK_DEBUG=false

# Scan folder for video uploads
SCAN_FOLDER=uploads
